<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Camera Capture</title>

<style>
body {
  font-family: sans-serif;
  text-align: center;
  margin-top: 40px;
}

button {
  padding: 15px 25px;
  font-size: 18px;
}
</style>
</head>

<body>

<h2>Prendre une photo</h2>

<input
  type="file"
  accept="image/*"
  capture="environment"
  id="cameraInput"
  style="display:none"
/>

<button onclick="openCamera()">📸 Ouvrir la caméra</button>

<script>

function openCamera() {
  document.getElementById("cameraInput").click();
}

document
.getElementById("cameraInput")
.addEventListener("change", function(event) {

  const file = event.target.files[0];

  if (!file) return;

  const reader = new FileReader();

  reader.onload = function(e) {

    const base64 = e.target.result;

    window.parent.postMessage({
      type: "cameraImage",
      image: base64,
      filename: file.name,
      size: file.size,
      mime: file.type
    }, "*");

  };

  reader.readAsDataURL(file);

});

</script>

</body>
</html>
